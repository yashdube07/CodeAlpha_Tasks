#include <iostream>
#include <iomanip>
using namespace std;

int main() {
    int numCourses;
    char grade;
    float creditHours;
    float totalCredits = 0, totalGradePoints = 0;
    int gradePoint;

    cout << "Enter the number of courses: ";
    cin >> numCourses;

    for (int i = 1; i <= numCourses; i++) {
        cout << "\nCourse " << i << endl;
        cout << "Enter Grade (O/A/B/C/D/F): ";
        cin >> grade;
        cout << "Enter Credit Hours: ";
        cin >> creditHours;

        switch (grade) {
            case 'O': gradePoint = 10; break;
            case 'A': gradePoint = 9; break;
            case 'B': gradePoint = 8; break;
            case 'C': gradePoint = 7; break;
            case 'D': gradePoint = 6; break;
            case 'F': gradePoint = 0; break;
            default:
                cout << "Invalid Grade!" << endl;
                return 0;
        }
        totalCredits += creditHours;
        totalGradePoints += gradePoint * creditHours;

        cout << "Grade: " << grade
             << " | Credits: " << creditHours << endl;
    }
    float GPA = totalGradePoints / totalCredits;
    float CGPA = GPA;  // Assuming only one semester

    cout << "\n===== Result =====" << endl;
    cout << "Total Credits: " << totalCredits << endl;
    cout << "Total Grade Points: " << totalGradePoints << endl;
    cout << fixed << setprecision(2);
    cout << "GPA: " << GPA << endl;
    cout << "CGPA: " << CGPA << endl;

    return 0;
}
